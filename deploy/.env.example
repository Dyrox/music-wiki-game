# Docker image tag. CI passes this dynamically, but manual deploys can set it here.
IMAGE=ghcr.io/OWNER/REPO:latest

# For dyrox.cat/musicwiki through nginx, keep the app private on localhost.
APP_BIND=127.0.0.1
APP_PORT=4000

# Optional upstream/API tuning.
NCM_BASE=https://api-enhanced-gamma-sandy.vercel.app
SONG_PAGE_SIZE=100
MAX_SONG_PAGES=4
LITE_SONG_LIMIT=100
BFS_MAX_DEPTH=5
BFS_NEIGHBOR_CAP=14
ROUND_MS=180000
ARTIST_TTL_MS=21600000
SEARCH_TTL_MS=3600000
